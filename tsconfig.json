{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "isolatedModules": true,
    "module": "nodenext",
    "target": "es2024",
    "moduleResolution": "nodenext",
    "types": ["node", "jest"],
    "skipLibCheck": true,
    "strict": true,
    "outDir": "./dist"
  },
  "include": ["src", "tests", "jest.config.js"]
}
